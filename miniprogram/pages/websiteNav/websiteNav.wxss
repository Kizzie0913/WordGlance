/* pages/websiteNav/websiteNav.wxss */
/* 英语学习网站导航 */

.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 顶部 */
.header {
  background: linear-gradient(135deg, #007aff, #5856d6);
  padding: 48rpx 30rpx 40rpx;
  color: #fff;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}
.header-desc {
  font-size: 24rpx;
  opacity: 0.85;
}

/* 网站网格 - CSS Grid 2列布局 */
.site-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 24rpx;
}

.site-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
  min-height: 280rpx;
  width: 100%;
  box-sizing: border-box;
}

.site-card:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.site-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: #f0f2f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}
.site-icon {
  font-size: 40rpx;
}

.site-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.site-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}

.site-copy-btn {
  margin-top: auto;
  padding: 8rpx 20rpx;
  background: rgba(0,122,255,0.1);
  border-radius: 16rpx;
  transition: all 0.2s;
}
.site-copy-btn:active {
  background: rgba(0,122,255,0.2);
}
.copy-text {
  font-size: 22rpx;
  color: #007aff;
  font-weight: 500;
}

/* 空状态 */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}
.empty-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
