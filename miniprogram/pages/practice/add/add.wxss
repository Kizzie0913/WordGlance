/* pages/practice/add/add.wxss */
/* 添加做题记录 - 表格输入 */

page {
  width: 100%;
  overflow-x: hidden;
  background: #f5f5f5;
}

.page {
  width: 100%;
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 240rpx;
  box-sizing: border-box;
}

/* 分区标题 */
.section {
  margin: 24rpx 24rpx 0;
  padding: 32rpx;
  box-sizing: border-box;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  display: block;
}

/* 分类选择卡片 */
.cat-cards {
  display: flex;
  gap: 20rpx;
}
.cat-card {
  flex: 1;
  background: #f8f8f8;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 3rpx solid transparent;
  transition: all 0.2s;
  position: relative;
}
.cat-card.cat-active {
  background: #e8f8ee;
  border-color: #07c160;
}
.cat-emoji { font-size: 56rpx; margin-bottom: 12rpx; }
.cat-label { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 8rpx; }
.cat-types { font-size: 20rpx; color: #999; text-align: center; line-height: 1.4; }
.cat-check {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

/* 得分表格 */
.score-table {
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #eee;
}
.table-header {
  display: flex;
  align-items: center;
  background: #07c160;
  padding: 18rpx 16rpx;
}
.th-name, .th-score, .th-full, .th-accuracy {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  text-align: center;
}
.th-name { flex: 2; text-align: left; padding-left: 8rpx; }
.th-score { flex: 2; }
.th-full { flex: 1.5; }
.th-accuracy { flex: 1.5; }

.table-row {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #fff;
}
.table-row:last-child { border-bottom: none; }
.td-name {
  flex: 2;
  font-size: 26rpx;
  color: #333;
  padding-left: 8rpx;
}
.td-score {
  flex: 2;
  display: flex;
  justify-content: center;
}
.td-input {
  width: 120rpx;
  height: 64rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}
.td-input:focus {
  border-color: #07c160;
  background: #fff;
}
.td-full {
  flex: 1.5;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}
.td-accuracy {
  flex: 1.5;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
}

/* 正确率颜色 */
.acc-great { color: #07c160; }
.acc-good { color: #ff9500; }
.acc-bad  { color: #ff3b30; }

/* 合计行 */
.table-total {
  background: #f8f9fa;
  font-weight: 600;
}
.td-total-label { font-weight: 700; color: #333; }
.td-total-val { font-weight: 600; color: #333; }

/* 补充信息 */
.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.info-row:last-child { margin-bottom: 0; }
.info-label {
  font-size: 26rpx;
  color: #666;
  width: 200rpx;
  flex-shrink: 0;
}
.info-input {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}
.info-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 正确率预览 */
.preview-card {
  margin: 24rpx 24rpx 0;
}
.preview-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.preview-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.preview-label { font-size: 26rpx; color: #999; }
.preview-value {
  font-size: 56rpx;
  font-weight: 800;
}
.preview-detail { font-size: 24rpx; color: #999; }

/* 环形预览 */
.preview-ring {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: conic-gradient(#07c160 0deg, #eee 0deg);
}
.ring-mask {
  position: absolute;
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: #fff;
}
.ring-text {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

/* 保存按钮 */
.bottom-btn-area {
  padding: 30rpx 40rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}
.save-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.save-btn.btn-disabled {
  background: #ccc;
  color: #fff;
}
.save-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}
