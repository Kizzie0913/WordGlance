/* pages/vocabularyLibrary/vocabularyLibrary.wxss */

/* Tab切换 */
.tab-bar {
  display: flex;
  padding: 0;
  overflow: hidden;
}

.tab-item {
  flex:1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #07c160;
  font-weight: bold;
  border-bottom-color: #07c160;
}

/* 空状态 */
.empty-card {
  text-align: center;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 10rpx;
}

/* 生词列表 */
.vocab-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.15s;
}
.vocab-item:last-child {
  border-bottom: none;
}
.vocab-item:active {
  background: #f9f9f9;
  border-radius: 12rpx;
}

.vocab-main {
  flex:1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.vocab-en {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.vocab-phonetic {
  font-size: 22rpx;
  color: #07c160;
}

.vocab-cn {
  font-size: 26rpx;
  color: #666;
}

/* 操作按钮组（标签+删除） */
.vocab-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.vocab-del {
  padding: 8rpx 12rpx;
}

.del-text {
  font-size: 28rpx;
}

/* 语料列表 */
.corpus-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.corpus-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.corpus-del {
  padding: 8rpx 12rpx;
}

.corpus-content {
  padding: 16rpx 0;
}

.corpus-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.corpus-time {
  font-size: 22rpx;
  color: #bbb;
  display: block;
}

/* 语料标题行（标题 + 场景标签） */
.corpus-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.corpus-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

/* 场景标签样式 */
.corpus-scene-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  line-height: 1.4;
}

/* 场景筛选栏 */
.scene-filter {
  display: flex;
  padding: 16rpx 32rpx;
  gap: 16rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.scene-tag {
  display: inline-block;
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 28rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.scene-tag-active {
  color: #fff;
  background: linear-gradient(135deg, #667eea, #764ba2);
  font-weight: 500;
}

/* 用户信息 */
.user-bottom-card {
  margin-top: 30rpx;
}

.user-row {
  display: flex;
  align-items: center;
}

.user-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.user-name-text {
  flex:1;
  font-size: 28rpx;
  color: #333;
}

.user-action {
  font-size: 24rpx;
  color: #07c160;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.clear-link {
  font-size: 24rpx;
  color: #999;
}

/* ======================================== */
/* ========== 词典详情弹窗样式 ========== */
/* ======================================== */

.dict-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.dict-panel {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 32rpx 48rpx;
  overflow-y: auto;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.dict-header {
  position: sticky;
  top: 0;
  background: #fff;
  padding: 32rpx 0 20rpx;
  z-index: 1;
  border-bottom: 2rpx solid #f0f0f0;
}
.dict-word-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.dict-word {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}
.dict-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f0f0f0;
  font-size: 28rpx;
  color: #999;
}
.dict-close:active {
  background: #e0e0e0;
}

.dict-phonetic-row {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-top: 16rpx;
}
.dict-phonetic-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #f0fdf4;
  border-radius: 24rpx;
}
.dict-phonetic-item:active {
  background: #dcfce7;
  transform: scale(0.96);
}
.phonetic-label {
  font-size: 20rpx;
  font-weight: 700;
  background: #07c160;
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}
.phonetic-text {
  font-size: 24rpx;
  color: #555;
  font-style: italic;
}
.phonetic-play {
  font-size: 28rpx;
}

.dict-loading {
  padding: 60rpx 0;
  text-align: center;
}
.dict-loading-text {
  font-size: 28rpx;
  color: #999;
}

.dict-meanings {
  margin-top: 24rpx;
}
.dict-meaning-group {
  margin-bottom: 24rpx;
}
.dict-meaning-group:last-child {
  margin-bottom: 0;
}
.dict-pos-row {
  margin-bottom: 12rpx;
}
.dict-pos-tag {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  background: #07c160;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
}
.dict-pos-none {
  background: #999;
}
.dict-def-list {
  padding-left: 8rpx;
}
.dict-def-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 10rpx 0;
  line-height: 1.6;
}
.dict-def-num {
  min-width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  border-radius: 50%;
  font-size: 20rpx;
  color: #888;
  font-weight: 600;
  margin-top: 4rpx;
}
.dict-def-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.dict-forms {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}
.dict-forms-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
  margin-bottom: 12rpx;
}
.dict-forms-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.dict-form-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}
.form-name {
  font-size: 22rpx;
  color: #999;
}
.form-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 双语例句 */
.dict-examples {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}
.dict-examples-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.dict-example-item {
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  border-left: 6rpx solid #07c160;
}
.dict-example-item:last-child {
  margin-bottom: 0;
}
.example-en {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}
.example-num {
  min-width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07c160;
  color: #fff;
  border-radius: 50%;
  font-size: 18rpx;
  font-weight: 600;
  margin-top: 4rpx;
  flex-shrink: 0;
}
.example-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  flex: 1;
}
.example-zh {
  padding-left: 38rpx;
  margin-top: 8rpx;
}
.example-text-zh {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}
