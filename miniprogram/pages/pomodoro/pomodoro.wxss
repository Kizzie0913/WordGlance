/* pages/pomodoro/pomodoro.wxss */

.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 60rpx;
}

/* 顶部 */
.header {
  background: linear-gradient(135deg, #ff6347, #ff8c69);
  padding: 48rpx 30rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.header-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.back-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: rgba(255,255,255,0.22);
  border-radius: 30rpx;
}
.back-icon { font-size: 36rpx; color: #fff; font-weight: bold; }
.back-text { font-size: 26rpx; color: #fff; }
.back-btn:active { background: rgba(255,255,255,0.35); }
.header-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.header-placeholder {
  width: 120rpx;
}
.header-title { font-size: 44rpx; font-weight: bold; color: #fff; }
.header-sub  { font-size: 26rpx; color: rgba(255,255,255,0.85); margin-top: 8rpx; }

/* 计时器区域 */
.timer-section {
  padding: 30rpx 0 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Canvas 容器 */
.ring-box {
  position: relative;
  width: 420rpx;
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.timer-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 420rpx;
  height: 420rpx;
  pointer-events: none;
}
/* 中央时间 */
.ring-center {
  position: relative;
  z-index: 2;
  width: 284rpx;
  height: 284rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.timer-time {
  font-size: 80rpx;
  font-weight: bold;
  color: #1a1a1a;
  font-variant-numeric: tabular-nums;
  letter-spacing: 2rpx;
  line-height: 1;
}
.timer-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 控制按钮 */
.timer-controls {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-top: 36rpx;
}
.ctrl-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.12);
}
.ctrl-icon { font-size: 48rpx; margin-bottom: 2rpx; }
.ctrl-text { font-size: 22rpx; color: #fff; font-weight: 600; }
.start-btn { background: linear-gradient(135deg, #ff6347, #ff8c69); }
.pause-btn { background: linear-gradient(135deg, #f0a020, #f5c542); }
.reset-btn { background: linear-gradient(135deg, #8e8e93, #aeaeb2); }
.skip-btn  { background: linear-gradient(135deg, #5ac8fa, #007aff); }

/* 番茄计数 */
.tomato-card {
  margin: 20rpx 30rpx 0;
  padding: 36rpx;
}
.counter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.counter-label { font-size: 28rpx; font-weight: 600; color: #333; }
.counter-total { font-size: 28rpx; font-weight: bold; color: #ff6347; }
.counter-tomatoes {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.tomato-icon  { font-size: 44rpx; }
.counter-empty { font-size: 26rpx; color: #bbb; }
.counter-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}
.counter-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff6347, #ff8c69);
  border-radius: 8rpx;
  transition: width 0.4s ease;
}
.counter-hint { font-size: 24rpx; color: #999; }

/* 目标 */
.goal-card {
  margin: 24rpx 30rpx 0;
  padding: 30rpx 36rpx;
}
.goal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.goal-title { font-size: 28rpx; font-weight: 600; color: #333; }
.goal-adjust { display: flex; align-items: center; gap: 24rpx; }
.goal-btn {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #555;
}
.goal-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6347;
  min-width: 60rpx;
  text-align: center;
}

/* 提示 */
.tips-card {
  margin: 24rpx 30rpx 0;
  padding: 28rpx 36rpx;
  background: #fffbe6;
  border: 2rpx solid #fff1b8;
}
.tip-text { font-size: 26rpx; color: #ad8b00; line-height: 1.6; }

/* 预设选择行 */
.preset-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx 30rpx 0;
  margin-top: 24rpx;
  position: relative;
  z-index: 2;
}
.preset-tag {
  font-size: 24rpx;
  color: #888;
  background: #fff;
  border-radius: 30rpx;
  padding: 10rpx 28rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.preset-tag.active {
  color: #ff6347;
  border-color: #ff6347;
  background: #fff5f3;
  font-weight: 600;
}

/* ============ 时长编辑弹窗 ============ */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-box {
  width: 580rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 50rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 60rpx rgba(0,0,0,0.15);
}
.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 40rpx;
}
.modal-stepper {
  display: flex;
  align-items: center;
  gap: 30rpx;
}
.stepper-btn {
  width: 100rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #555;
}
.stepper-btn:active {
  background: #eaeaea;
}
.stepper-value {
  font-size: 64rpx;
  font-weight: bold;
  color: #ff6347;
  min-width: 140rpx;
  text-align: center;
}
.modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 50rpx;
  width: 100%;
}
.modal-cancel {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #666;
  font-weight: 600;
}
.modal-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #ff6347, #ff8c69);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}
.modal-cancel:active { background: #eaeaea; }
.modal-confirm:active { opacity: 0.85; }

/* ============ 设置弹窗 ============ */
.settings-box {
  padding: 50rpx 40rpx 40rpx !important;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.setting-item:last-of-type {
  border-bottom: none;
}

.setting-label {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.setting-emoji {
  font-size: 40rpx;
}

.setting-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.setting-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6347;
}

.setting-unit {
  font-size: 24rpx;
  color: #999;
}

.setting-edit {
  font-size: 28rpx;
  margin-left: 8rpx;
}

.setting-value:active {
  background: #f0f0f0;
}

.settings-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 30rpx;
  padding: 20rpx 24rpx;
  background: #f0f9ff;
  border-radius: 16rpx;
  border: 2rpx solid #e6f7ff;
}

.tip-icon {
  font-size: 32rpx;
}

.settings-tip text:last-child {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 设置按钮样式 */
.setting-tag {
  background: #fff !important;
  color: #666 !important;
  border: 2rpx solid #e0e0e0 !important;
}

.setting-tag.active {
  color: #ff6347 !important;
  border-color: #ff6347 !important;
  background: #fff5f3 !important;
}
