/* pages/login/login.wxss */

.login-page {
  min-height: 100vh;
  background: #f7f7f7;
  position: relative;
  overflow: hidden;
}

/* 波点装饰 */
.dots-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

.dot {
  position: absolute;
  border-radius: 50%;
  opacity: 0.12;
}

/* 主要内容 */
.login-content {
  position: relative;
  z-index: 1;
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo区域 */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  margin-top: 40rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160, #5ac8fa);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.3);
}

.logo-emoji {
  font-size: 80rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: #999;
}

/* 功能亮点卡片 */
.feature-card {
  width: 100%;
  margin-bottom: 60rpx;
}

.feature-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.feature-emoji {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 8rpx 0;
}

/* 老用户欢迎卡片 */
.welcome-card {
  width: 100%;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 40rpx 40rpx;
}

.welcome-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.welcome-avatar-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffecd2, #fcb69f);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(252, 182, 159, 0.35);
}

.welcome-avatar-emoji {
  font-size: 80rpx;
}

.welcome-nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.welcome-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.bind-hint {
  width: 100%;
  padding: 20rpx 24rpx;
  background: rgba(7, 193, 96, 0.08);
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.bind-hint-text {
  font-size: 24rpx;
  color: #07c160;
  line-height: 1.5;
}

/* 昵称输入卡片（新用户） */
.nickname-input-card {
  width: 100%;
  margin-bottom: 40rpx;
}

.input-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.avatar-preview {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
}

.avatar-preview-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 2rpx solid #e0e0e0;
}

.avatar-preview-emoji {
  font-size: 72rpx;
}

.avatar-preview-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.avatar-preview-text {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.refresh-avatar-btn {
  padding: 12rpx 32rpx;
  background: rgba(88, 86, 214, 0.1);
  border-radius: 30rpx;
}

.refresh-avatar-btn text {
  font-size: 26rpx;
  color: #5856d6;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160, #5ac8fa);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

/* 登录按钮 */
.login-btns {
  width: 100%;
  margin-bottom: 40rpx;
}

.wechat-btn {
  width: 100%;
  height: 96rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: none;
}

.wechat-btn::after {
  border: none;
}

.wechat-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.guest-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.guest-text {
  font-size: 28rpx;
  color: #999;
}

/* 隐私协议 */
.privacy {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.privacy-text {
  font-size: 22rpx;
  color: #999;
}

.privacy-link {
  font-size: 22rpx;
  color: #07c160;
  margin: 0 6rpx;
}

/* 找回账号 */
.recover-row {
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
  margin-bottom: 20rpx;
}

.recover-link {
  font-size: 24rpx;
  color: #667eea;
  padding: 12rpx 24rpx;
  background: rgba(102,126,234,0.08);
  border-radius: 24rpx;
}

.recover-card {
  width: 100%;
  margin-bottom: 30rpx;
  padding: 36rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.recover-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.recover-hint {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.recover-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
  text-align: center;
}

.recover-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
