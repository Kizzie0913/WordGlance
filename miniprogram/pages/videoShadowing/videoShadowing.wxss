/* pages/videoShadowing/videoShadowing.wxss */

/* ===== 步骤0：上传区域 ===== */
.upload-area {
  min-height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 60rpx;
  padding: 0;
  background: transparent;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 400rpx;
  padding: 60rpx 0;
  background: #fff;
  border: 2rpx dashed #5856d6;
  border-radius: 24rpx;
  font-size: 34rpx;
  color: #333;
  line-height: 1.6;
}

.upload-btn::after {
  border: none;
}

.upload-btn-hover {
  background: #f0f0f0;
}

.upload-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.upload-text {
  font-size: 34rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
}

/* ===== 步骤1：字幕输入 ===== */
.video-info-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
}

.video-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.btn-change {
  font-size: 26rpx;
  color: #07c160;
  padding: 8rpx 20rpx;
  border: 1rpx solid #07c160;
  border-radius: 20rpx;
}

.subtitle-input-card {
  padding: 30rpx;
}

.subtitle-textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.subtitle-tips {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: rgba(88, 86, 214, 0.05);
  border-radius: 8rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #5856d6;
}

/* 确认按钮 */
.btn-primary {
  margin: 30rpx 24rpx;
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

/* ===== 步骤2：播放器 ===== */
.player-card {
  padding: 20rpx;
}

.video-player {
  width: 100%;
  height: 420rpx;
  border-radius: 16rpx;
  background: #000;
}

/* 倍速控制 */
.speed-control {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 0 10rpx;
}

.speed-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
  white-space: nowrap;
}

.speed-btns {
  display: flex;
  gap: 12rpx;
  flex: 1;
}

.speed-btn {
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  white-space: nowrap;
}

.speed-btn.active {
  background: #07c160;
  color: #fff;
}

/* 播放器操作按钮 */
.player-actions {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
  padding: 0 10rpx;
}

.p-action {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
}

/* ===== 字幕区域 ===== */
.subtitle-card {
  padding: 30rpx;
}

.subtitle-list {
  max-height: 500rpx;
  overflow-y: auto;
}

.subtitle-item {
  padding: 16rpx 12rpx;
  border-left: 4rpx solid transparent;
  margin-bottom: 4rpx;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.subtitle-item.active {
  background: rgba(7, 193, 96, 0.1);
  border-left-color: #07c160;
}

.sub-en {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
  line-height: 1.5;
}

.sub-cn {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

/* ===== 提取单词 ===== */
.ext-word-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.ext-word-item:last-child {
  border-bottom: none;
}

.ext-word-main {
  flex: 1;
}

.ext-word-en {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.ext-word-phonetic {
  font-size: 22rpx;
  color: #07c160;
}

.ext-word-cn {
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.ext-word-btn {
  padding: 8rpx 16rpx;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.ext-word-speak {
  padding: 12rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.speak-icon {
  font-size: 36rpx;
}

/* ===== 加载提示 ===== */
.loading-card {
  text-align: center;
  padding: 30rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #5856d6;
}

/* ===== 录音区域 ===== */
.record-card {
  padding: 30rpx;
}

.record-area {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 16rpx 0;
  flex-wrap: wrap;
}

.record-btn {
  padding: 16rpx 40rpx;
  background: #ff2d55;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.record-btn.recording {
  background: #999;
}

.play-btn {
  padding: 16rpx 30rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #333;
}

/* ===== 通用 ===== */
.card-hover {
  background: #f0f0f0 !important;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-green {
  background: rgba(7, 193, 96, 0.1);
  color: #07c160;
}

.tag-purple {
  background: rgba(88, 86, 214, 0.1);
  color: #5856d6;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

.action-text {
  font-size: 28rpx;
}
