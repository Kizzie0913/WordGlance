/* app.wxss - 全局样式 */

/* 基础重置 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
  box-sizing: border-box;
}

/* 全局彩色波点装饰 - 用伪元素实现 */
.page-container {
  position: relative;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

/* 波点背景装饰 */
.dots-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.dots-bg .dot {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}

/* 通用卡片样式 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
}

/* 通用按钮样式 */
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary::after {
  border: none;
}

/* 通用标签样式 */
.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.tag-green {
  background: rgba(7, 193, 96, 0.1);
  color: #07c160;
}

.tag-orange {
  background: rgba(255, 149, 0, 0.1);
  color: #ff9500;
}

.tag-purple {
  background: rgba(88, 86, 214, 0.1);
  color: #5856d6;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-state .empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: #999;
}